# 后端（Node）部署时使用。复制为 .env 后填入真实值，勿提交 .env 到 Git。

# ===========================================
# MySQL 数据库配置（TiDB Cloud）
# ===========================================

# TiDB Cloud 主机地址（以 .tidb-cloud.com 结尾）
MYSQL_HOST=gateway01.ap-southeast-1.prod.aws.tidbcloud.com

# TiDB Cloud 端口（默认 4000）
MYSQL_PORT=4000

# 数据库名称（建议使用下划线代替空格，如 mingqing_agricultural_database）
MYSQL_DATABASE=mingqing_agricultural_database

# 用户名（格式为：集群名.root 或你创建的用户）
MYSQL_USER=aKp6i8j624HvpKh.root

# 密码（在 TiDB Cloud 控制台中设置或查看）
MYSQL_PASSWORD=your_password_here

# 是否启用 SSL（TiDB Cloud 必须设为 true）
MYSQL_SSL=true

# ===========================================
# 服务端口配置
# ===========================================

# 本地开发端口
PORT=4000

# ===========================================
# 前端 API 地址（仅前端需要）
# ===========================================

# 生产环境：设置为 Render 后端地址
# VITE_API_URL=https://your-app-name.onrender.com
